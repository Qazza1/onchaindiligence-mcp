# --- Companies House (free UK gov data) ---
COMPANIES_HOUSE_API_KEY=

# --- Sanctions oracle (Ethereum RPC; default works, override if rate-limited) ---
SANCTIONS_ORACLE_RPC_URL=https://ethereum-rpc.publicnode.com
SANCTIONS_ORACLE_ADDRESS=

# --- x402 payment (USDC on Base) ---
# A BASE address to receive USDC (NOT your Tempo recipient).
X402_RECIPIENT_ADDRESS=
# 'base-sepolia' for testing with fake money, 'base' for real USDC.
X402_NETWORK=base-sepolia
# Coinbase Developer Platform API keys (from your CDP account).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
